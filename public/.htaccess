# ----------------------------------------------------------------------
# 1. PÁGINAS DE ERROR PERSONALIZADAS
# ----------------------------------------------------------------------
ErrorDocument 404 /404.html

# ----------------------------------------------------------------------
# 2. MOTOR DE REESCRITURA (RUTAS, DOMINIOS Y SEGURIDAD)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase

    # A. Forzar HTTPS siempre y QUITAR "www" (Evita contenido duplicado en Google)
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteRule ^(.*)$ https://pixeltechcol.com/$1 [L,R=301]
    
    
    # B. Quitar /index.html de la URL de inicio (SEO)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
    RewriteRule ^index\.html$ / [R=301,L]

    # C. REESCRITURA DE SITEMAP Y GOOGLE FEED (Firebase Functions Proxy)
    RewriteRule ^sitemap\.xml$ serve_sitemap.php [L]
    RewriteRule ^google-feed\.xml$ serve_feed.php [L]

    # D. REDIRECCIONES 301 (LIMPIEZA DE RASTRO DE WOOCOMMERCE)
    RewriteRule ^catalogo\.html$ /shop/catalog.html [R=301,L]
    RewriteRule ^catalog\.html$ /shop/catalog.html [R=301,L]
    RewriteRule ^etiqueta-producto/?(.*)$ /shop/catalog.html [R=301,L]
    RewriteRule ^categoria-producto/?(.*)$ /shop/catalog.html [R=301,L]
    RewriteRule ^tienda/?(.*)$ / [R=301,L]
    RewriteRule ^producto/?(.*)$ / [R=301,L]
    RewriteRule ^faqs/?(.*)$ / [R=301,L]
    RewriteRule ^carrito/?(.*)$ / [R=301,L]
    RewriteRule ^finalizar-compra/?(.*)$ / [R=301,L]
    RewriteRule ^mi-cuenta/?(.*)$ / [R=301,L]
    RewriteRule ^wp-content/?(.*)$ / [R=301,L]

    # E. Ocultar extensión .html en la barra de direcciones (Nuevas URLs Limpias)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# ----------------------------------------------------------------------
# 3. COMPRESIÓN GZIP / DEFLATE (Para que la web cargue rápido)
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    <IfModule mod_setenvif.c>
        <IfModule mod_headers.c>
            SetEnvIfNoCase ^(Accept-EncodXng|X-cept-Encoding|X{15}|~{15}|-{15})$ ^((gzip|deflate)\s*,?\s*)+|[X~-]{4,13}$ HAVE_Accept-Encoding
            RequestHeader append Accept-Encoding "gzip,deflate" env=HAVE_Accept-Encoding
            # No comprimir archivos que ya están comprimidos
            SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|rar|zip|exe|flv|mov|wma|mp3|avi|swf|mp?g|mp4|webm|webp|pdf)$ no-gzip dont-vary
        </IfModule>
    </IfModule>
    <IfModule mod_filter.c>
        AddOutputFilterByType DEFLATE application/atom+xml application/javascript application/json application/rss+xml application/vnd.ms-fontobject application/x-font-ttf application/xhtml+xml application/xml font/opentype image/svg+xml image/x-icon text/css text/html text/plain text/x-component text/xml
    </IfModule>
    <IfModule mod_headers.c>
        Header append Vary: Accept-Encoding
    </IfModule>
</IfModule>

# ----------------------------------------------------------------------
# 4. CACHÉ DEL NAVEGADOR (Mejora la velocidad de carga)
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive on
    ExpiresDefault                              "access plus 1 month"
    
    # HTML y Datos dinámicos (No cachear para ver cambios al instante)
    ExpiresByType text/html                     "access plus 0 seconds"
    ExpiresByType text/xml                      "access plus 0 seconds"
    ExpiresByType application/xml               "access plus 0 seconds"
    ExpiresByType application/json              "access plus 0 seconds"
    
    # Recursos multimedia (Cachear por 4 meses)
    ExpiresByType image/gif                     "access plus 4 months"
    ExpiresByType image/png                     "access plus 4 months"
    ExpiresByType image/jpeg                    "access plus 4 months"
    ExpiresByType image/webp                    "access plus 4 months"
    ExpiresByType image/avif                    "access plus 4 months"
    ExpiresByType video/mp4                     "access plus 4 months"
    ExpiresByType video/webm                    "access plus 4 months"
    
    # Fuentes web
    ExpiresByType font/ttf                      "access plus 4 months"
    ExpiresByType font/otf                      "access plus 4 months"
    ExpiresByType font/woff                     "access plus 4 months"
    ExpiresByType font/woff2                    "access plus 4 months"
    ExpiresByType image/svg+xml                 "access plus 4 months"
    
    # CSS y JavaScript (Cachear por 1 año)
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
</IfModule>

# ----------------------------------------------------------------------
# 5. MANEJADOR DE PHP DE CPANEL
# ----------------------------------------------------------------------
# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ----------------------------------------------------------------------
# 6. SEO & INYECCIÓN DINÁMICA (PARA TODOS: HUMANOS Y BOTS)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # A. Verificar que intentan leer el detalle de un producto
    RewriteCond %{REQUEST_URI} ^/shop/product\.html$ [NC]
    
    # B. Capturar el ID del producto de la URL (?id=xxxx)
    RewriteCond %{QUERY_STRING} id=([a-zA-Z0-9_-]+)
    
    # C. Ejecutar internamente el script PHP para TODO el tráfico
    RewriteRule ^(.*)$ serve_product_meta.php?id=%1 [L]
</IfModule>